# Copy to `.env` and fill in. Never commit real secrets — only this template.
# `.env` is git-ignored; docker-compose and the app both read it.

NODE_ENV=development

# --- Postgres container (docker-compose only) ---
POSTGRES_USER=adf
POSTGRES_PASSWORD=adf
POSTGRES_DB=adf
# Host port offset to avoid clashing with sibling projects on 5432.
POSTGRES_PORT=5433

# --- Database (app) — must match the Postgres container above ---
DATABASE_URL=postgresql://adf:adf@localhost:5433/adf

# --- Auth (better-auth) ---
# Generate a real secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3000

# --- Mail (Mailpit in dev; any SMTP provider in prod) ---
MAIL_HOST=localhost
MAIL_PORT=1026
MAILPIT_UI_PORT=8026
MAIL_USER=
MAIL_PASSWORD=
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_IGNORE_TLS=true
MAIL_DEFAULT_EMAIL=noreply@africadigitalforum.test
MAIL_DEFAULT_NAME=Africa Digital Forum

# --- Object storage (SeaweedFS S3 in dev) ---
SEAWEEDFS_S3_PORT=8433
SEAWEEDFS_FILER_PORT=8988
SEAWEEDFS_MASTER_PORT=9433
STORAGE_ENDPOINT=http://localhost:8433
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=adf-storage
STORAGE_SECRET_KEY=adf-storage-secret
STORAGE_PRIVATE_BUCKET=adf-private
STORAGE_PUBLIC_BUCKET=adf-public
# Leave blank in dev → getPublicUrl() falls back to ${STORAGE_ENDPOINT}/${STORAGE_PUBLIC_BUCKET}.
# In prod, set to the CDN hostname in front of the public bucket.
STORAGE_PUBLIC_BASE_URL=
STORAGE_FORCE_PATH_STYLE=true
STORAGE_AUTO_CREATE_BUCKET=true

# --- Seed super-admin (used by the seed CLI in M1) ---
SEED_ADMIN_PASSWORD=replace-me-dev-admin-password

# --- Client (VITE_-prefixed, bundled to the browser) ---
VITE_PUBLIC_SITE_URL=http://localhost:3000
